{
  "mcpServers": {
    "gkg": {
      "url": "http://localhost:27495/mcp"
    },
    "MCP_DOCKER": {
      "command": "docker",
      "args": ["mcp", "gateway", "run"]
    },
    "exa": {
      "url": "https://mcp.exa.ai/mcp"
    },
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "morph-mcp": {
      "command": "npx",
      "args": ["-y", "@morphllm/morphmcp"],
      "env": {
        "ENABLED_TOOLS": "warpgrep_codebase_search"
      }
    }
  }
}
